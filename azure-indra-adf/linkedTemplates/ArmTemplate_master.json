{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "azure-indra-adf"
		},
		"AzureDataLakeStorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage'"
		},
		"OnPremFiles_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'OnPremFiles'"
		},
		"AzureDataLakeStorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://azureindrastorage.dfs.core.windows.net/"
		},
		"OnPremFiles_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "C:\\Users\\Admin\\Desktop\\Azure Project\\CRM Sales Opportunity"
		},
		"OnPremFiles_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "Admin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "azure-indra-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage_accountKey": {
						"value": "[parameters('AzureDataLakeStorage_accountKey')]"
					},
					"OnPremFiles_password": {
						"value": "[parameters('OnPremFiles_password')]"
					},
					"AzureDataLakeStorage_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage_properties_typeProperties_url')]"
					},
					"OnPremFiles_properties_typeProperties_host": {
						"value": "[parameters('OnPremFiles_properties_typeProperties_host')]"
					},
					"OnPremFiles_properties_typeProperties_userId": {
						"value": "[parameters('OnPremFiles_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}